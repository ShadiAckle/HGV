# VDI local run — copied to .env in the deploy zip (npm start loads this file).
NODE_ENV=production
# If you edit values, edit .env (not .env.example) next to package.json.
# Auth: HGV disables user PATs. Use CLI OAuth once, then scripts/vdi-start.ps1 (injects token).
# COPY DATABRICKS_HOST from your VDI browser address bar (Workspace home URL) — do not guess digits.
#   databricks auth login --host <DATABRICKS_HOST> --profile hgv-edw
#   powershell -ExecutionPolicy Bypass -File .\scripts\vdi-start.ps1

DATABRICKS_HOST=https://REPLACE-WITH-YOUR-WORKSPACE-HOST.azuredatabricks.net
# Do NOT set DATABRICKS_CONFIG_PROFILE when using vdi-start.ps1 (SDK would re-call CLI / SCIM).
DATABRICKS_WAREHOUSE_ID=9e9c06ad1c397404
DATABRICKS_SERVING_ENDPOINT_NAME=databricks-classic-model-serving
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=hgv-ai
FLASK_RUN_HOST=127.0.0.1

COMP_CATALOG=edw_dev_hris
COMP_SCHEMA=hgv_comp
COMP_DATA_MODE=production
